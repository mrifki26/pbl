# Database
MYSQL_ROOT_PASSWORD=chili_root_password
MYSQL_DATABASE=chili_track
CHILI_TRACK_DATASOURCE_URL=jdbc:mysql://mysql:3306/chili_track?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
AUTH_DATASOURCE_URL=jdbc:mysql://mysql:3306/chili_auth?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
CONTROL_DATASOURCE_URL=jdbc:mysql://mysql:3306/chili_control?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=chili_root_password
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=false

# JWT
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-characters
JWT_EXPIRATION_MS=86400000

# Eureka
EUREKA_CLIENT_SERVICEURL_DEFAULTZONE=http://eureka-service:8761/eureka/
EUREKA_SERVER_ENABLE_SELF_PRESERVATION=true

# API Gateway
GATEWAY_CORS_ALLOWED_ORIGIN_PATTERNS=http://34.231.237.42:*,http://34.231.237.42:8085,http://localhost:*,http://127.0.0.1:*

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Host ports
MYSQL_HOST_PORT=3307
PHPMYADMIN_HOST_PORT=8080
EUREKA_HOST_PORT=8761
AUTH_HOST_PORT=8084
SOIL_HOST_PORT=8081
CONTROL_HOST_PORT=8082
TEMPERATURE_HOST_PORT=8083
API_GATEWAY_HOST_PORT=8085
PROMETHEUS_HOST_PORT=9090
GRAFANA_HOST_PORT=3000

# phpMyAdmin
PHPMYADMIN_UPLOAD_LIMIT=64M
